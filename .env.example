# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (pooled recommended for serverless)
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Email (Gmail SMTP via App Password) ───────────────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── AI (Anthropic) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Application ───────────────────────────────────────────────────────────────
PUBLIC_APP_URL=https://your-domain.com
ADMIN_EMAIL=owner@yourdomain.com
EMAIL_FROM="Picture Perfect TV Install <noreply@yourdomain.com>"
PORT=5000

# ── Client-side (must be prefixed VITE_) ──────────────────────────────────────
# Set this in Render dashboard — do not commit the real value
VITE_ADMIN_PASSWORD=your-admin-password

# Google Analytics 4 Measurement ID (optional — analytics disabled if unset)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── SMS / Twilio (optional — SMS disabled if unset) ───────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+14045551234
