{
  "include": ["client/src/**/*", "shared/**/*", "server/**/*"],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts",
    "client/src/components/admin/**/*",
    "client/src/components/customer/**/*",
    "client/src/components/ui/booking-confirmation-modal.tsx",
    "client/src/components/ui/booking-wizard.tsx",
    "client/src/components/ui/integrated-booking-wizard.tsx",
    "client/src/archive/**/*",
    "client/src/lib/googleCalendarService.ts",
    "client/src/lib/optimized-utils.ts",
    "client/src/lib/performance-monitor.ts",
    "client/src/lib/use-pricing.ts",
    "client/src/pages/admin/**/*",
    "client/src/pages/admin-bookings.tsx",
    "client/src/pages/admin.tsx",
    "client/src/pages/customer-login.tsx",
    "client/src/pages/customer-portal.tsx",
    "client/src/pages/customer-profile.tsx",
    "client/src/pages/email-previews.tsx",
    "client/src/pages/forgot-password.tsx",
    "client/src/pages/ManageBooking.tsx",
    "client/src/pages/reset-password.tsx",
    "client/src/pages/send-test-emails.tsx",
    "server/middleware/optimization.ts",
    "server/services/googleCalendarService.ts",
    "server/services/pushNotificationService.ts"
  ],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  }
}
